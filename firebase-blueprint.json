{
  "entities": {
    "User": {
      "title": "User",
      "description": "System user with specific role.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "registrar", "consultant", "meal_distributor"] },
        "displayName": { "type": "string" },
        "assignedDistricts": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "role"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Comprehensive patient record for the Sickle Cell Mitra Project Counselling Form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "contact": { "type": "string" },
        "address": { "type": "string" },
        "district": { "type": "string" },
        "block": { "type": "string" },
        "village": { "type": "string" },
        "abhaId": { "type": "string" },
        "aadharNumber": { "type": "string" },
        "sickleCellStatus": { "type": "string", "enum": ["SS", "AS", "AA"] },
        "preExistingDiagnosis": { "type": "boolean" },
        "dateOfDiagnosis": { "type": "string", "format": "date" },
        "reportsAttached": { "type": "boolean" },
        "firstSymptomOnset": { "type": "string", "format": "date" },
        "previousHospitalizations": { "type": "boolean" },
        "bloodTransfusionsCount": { "type": "number" },
        "otherHealthIssues": { "type": "string" },
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "otherSymptoms": { "type": "string" },
        "medicationHydroxyurea": { "type": "boolean" },
        "dosageHydroxyurea": { "type": "string" },
        "medicationFolicAcid": { "type": "boolean" },
        "dosageFolicAcid": { "type": "string" },
        "otherMedications": { "type": "string" },
        "medicationRegularity": { "type": "boolean" },
        "dietaryHabit": { "type": "string", "enum": ["Balanced", "Unbalanced"] },
        "dailyWaterIntake": { "type": "string" },
        "physicalActivity": { "type": "string", "enum": ["Regular", "None"] },
        "counsellingTopics": { "type": "array", "items": { "type": "string" } },
        "nutritionKitDistributed": { "type": "boolean" },
        "nutritionKitDate": { "type": "string", "format": "date" },
        "nutritionKitInstructionsProvided": { "type": "boolean" },
        "referral": { "type": "array", "items": { "type": "string" } },
        "feedbackConfirmation": { "type": "boolean" },
        "specificConcerns": { "type": "string" },
        "counsellorName": { "type": "string" },
        "counsellorDesignation": { "type": "string" },
        "counsellorOrganization": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_consultation", "pending_meal", "complete"] },
        "registrarNotes": { "type": "string" },
        "registrarImageUrl": { "type": "string" },
        "registrarId": { "type": "string" },
        "consultantAdvice": { "type": "string" },
        "consultantImageUrl": { "type": "string" },
        "consultantId": { "type": "string" },
        "mealDistributorNotes": { "type": "string" },
        "mealImageUrl": { "type": "string" },
        "mealDistributorId": { "type": "string" },
        "mealServedAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "age", "gender", "contact", "district", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles."
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient records spanning the clinic workflow."
    }
  }
}
